{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Team",
  "type": "object",
  "required": ["team_id", "minions"],
  "properties": {
    "team_id": {
      "type": "string",
      "description": "隊伍識別，用於戰報顯示"
    },
    "team_name": {
      "type": "string",
      "description": "隊伍顯示名稱（可選）"
    },
    "minions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "power", "stability"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "power": {
            "type": "number",
            "minimum": 1,
            "maximum": 9999
          },
          "stability": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 0.99
          },
          "skills": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 4,
            "default": []
          }
        }
      }
    }
  }
}
